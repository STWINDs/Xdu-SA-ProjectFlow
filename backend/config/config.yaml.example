server:
  port: 8080
  mode: debug

database:
  host: localhost
  port: 3306
  user: cowork
  password: "your_db_password"
  dbname: cowork
  charset: utf8mb4

redis:
  host: localhost
  port: 6379
  password: "your_redis_password"
  db: 0

minio:
  endpoint: localhost:9000
  access_key: minioadmin
  secret_key: "your_minio_secret"
  bucket: cowork
  use_ssl: false

jwt:
  access_secret: "change-me-to-a-random-string"
  refresh_secret: "change-me-to-another-random-string"
  access_ttl: 3600
  refresh_ttl: 604800
